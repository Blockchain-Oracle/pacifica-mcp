{
  "name": "@pacifica-dev/cli",
  "version": "0.1.3",
  "description": "CLI and core library for trading on Pacifica — the #1 Solana perps DEX. 36 tools for market data, trading, positions, and account management.",
  "type": "module",
  "bin": {
    "pacifica": "dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": [
    "pacifica",
    "solana",
    "perps",
    "dex",
    "trading",
    "mcp",
    "cli",
    "defi",
    "perpetuals"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/pacifica-mcp.git"
  },
  "homepage": "https://pacifica-mcp.xyz",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
