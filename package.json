{
  "name": "pacifica-mcp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @pacifica/web --filter @pacifica/docs -r --parallel dev",
    "dev:mcp": "pnpm --filter @pacifica/mcp dev",
    "dev:cli": "pnpm --filter @pacifica/cli dev",
    "dev:web": "pnpm --filter @pacifica/web dev",
